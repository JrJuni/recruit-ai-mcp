{
  "dashboard_title": "Pipeline Trend Review",
  "version": 1,
  "source_mode": "chart_ready",
  "database": "deal_intel",
  "collection": "dashboard_pipeline_trend",
  "description": "Atlas Charts specs for materialized pipeline trend rows. Run `deal-intel mongo refresh-chart-ready --target pipeline_trend --apply` before using these charts.",
  "parameters": {
    "window_start": "{{START_DATE}}",
    "window_end": "{{AS_OF_DATE}}",
    "lookback_days": "{{LOOKBACK_DAYS}}",
    "source_collection": "dashboard_pipeline_trend"
  },
  "charts": [
    {
      "id": "trend_kpis",
      "title": "Pipeline Trend KPIs",
      "chart_type": "table",
      "description": "Single materialized trend KPI row.",
      "pipeline": [
        {
          "$match": {
            "dashboard_id": "pipeline_trend",
            "chart_id": "trend_kpis",
            "schema_version": 1,
            "window_start": "{{START_DATE}}",
            "window_end": "{{AS_OF_DATE}}",
            "lookback_days": "{{LOOKBACK_DAYS}}"
          }
        },
        {
          "$project": {
            "_id": 0,
            "snapshot_count": 1,
            "deal_count": 1,
            "start_active_deal_count": 1,
            "end_active_deal_count": 1,
            "delta_active_deal_count": 1,
            "start_open_pipeline_value_amount": 1,
            "end_open_pipeline_value_amount": 1,
            "delta_open_pipeline_value_amount": 1,
            "pipeline_value_currency": 1
          }
        }
      ]
    },
    {
      "id": "trend_delta_bars",
      "title": "Pipeline Trend Delta",
      "chart_type": "bar_or_table",
      "description": "One materialized row per trend metric delta.",
      "pipeline": [
        {
          "$match": {
            "dashboard_id": "pipeline_trend",
            "chart_id": "trend_delta_bars",
            "schema_version": 1,
            "window_start": "{{START_DATE}}",
            "window_end": "{{AS_OF_DATE}}",
            "lookback_days": "{{LOOKBACK_DAYS}}"
          }
        },
        {
          "$sort": {
            "row_key": 1
          }
        },
        {
          "$project": {
            "_id": 0,
            "metric": 1,
            "start_value": 1,
            "end_value": 1,
            "delta": 1
          }
        }
      ]
    }
  ]
}
