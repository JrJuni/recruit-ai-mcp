# LLM provider keys. chatgpt_oauth uses CLI login and does not need an API key.
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
OPENAI_API_KEY=replace-with-openai-api-key

# MongoDB Atlas M0 free tier URI. Keep this secret in local env only.
# recruit-ai-mcp defaults to database recruit_ai and demo database recruit_ai_demo.
MONGODB_URI=replace-with-mongodb-atlas-uri
