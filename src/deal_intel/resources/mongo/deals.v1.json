{
  "id": "deals_collection_validator",
  "version": 1,
  "database": "deal_intel",
  "collection": "deals",
  "validation_action": "warn",
  "validation_level": "moderate",
  "description": "Permissive MongoDB validator for the full-profile deals collection. It catches obvious shape drift without blocking fast-changing MVP data.",
  "validator": {
    "$jsonSchema": {
      "bsonType": "object",
      "required": ["deal_id", "company", "deal_stage"],
      "additionalProperties": true,
      "properties": {
        "deal_id": {
          "bsonType": "string",
          "description": "Stable user-facing deal identifier."
        },
        "company": {
          "bsonType": "string"
        },
        "industry": {
          "bsonType": ["string", "null"]
        },
        "industry_tags": {
          "bsonType": ["array", "null"],
          "description": "Optional multi-select vertical tags. The primary industry should also appear here.",
          "items": {
            "bsonType": "string"
          }
        },
        "customer_segment": {
          "bsonType": ["string", "null"],
          "description": "Optional customer segment or maturity label such as startup, enterprise, public_sector, Series B, or Pre-IPO."
        },
        "deal_stage": {
          "enum": [
            "discovery",
            "qualification",
            "proposal",
            "negotiation",
            "stalled",
            "won",
            "lost"
          ]
        },
        "deal_size_amount": {
          "bsonType": ["int", "long", "double", "decimal", "null"]
        },
        "deal_size_currency": {
          "bsonType": ["string", "null"],
          "description": "ISO 4217-style currency code such as KRW or USD."
        },
        "deal_size_status": {
          "enum": [
            "unknown",
            "rough_estimate",
            "customer_budget",
            "quoted",
            "strategic_zero",
            null
          ]
        },
        "expected_close_date": {
          "bsonType": ["string", "date", "null"]
        },
        "actual_close_date": {
          "bsonType": ["string", "date", "null"]
        },
        "close_reason": {
          "bsonType": ["string", "null"]
        },
        "archived": {
          "bsonType": ["bool", "null"]
        },
        "is_sample": {
          "bsonType": ["bool", "null"]
        },
        "sample_batch_id": {
          "bsonType": ["string", "null"]
        },
        "meetings": {
          "bsonType": ["array", "null"]
        },
        "interactions": {
          "bsonType": ["array", "null"]
        },
        "stage_history": {
          "bsonType": ["array", "null"]
        },
        "customer_themes": {
          "bsonType": ["array", "null"]
        },
        "meddpicc_latest": {
          "bsonType": ["object", "null"]
        },
        "summary_embedding": {
          "bsonType": ["array", "null"]
        },
        "created_at": {
          "bsonType": ["string", "date", "null"]
        },
        "updated_at": {
          "bsonType": ["string", "date", "null"]
        }
      }
    }
  }
}
